# AI Gateway
AI_GATEWAY_URL=http://localhost:3500
GATEWAY_TIMEOUT_MS=500000

# Overrides de modelo (sobrescrevem ai-gateway.config.json > apps.personal-trainer)
# Se omitidos, usa os valores do app config no gateway
# Valores: low, medium, high (max so para Opus 4.6)
REASONING_EFFORT=low
# Max tokens de entrada (context window do modelo)
MAX_INPUT_TOKENS=200000
# Max tokens de saida
MAX_OUTPUT_TOKENS=64000

# Modelo IA
# No Firebase, use gemini-3-flash ou omita AI_MODEL para herdar o default do app no ai-gateway serverless.
AI_MODEL=

# Porta do servidor
PORT=3400

# Banco SQLite
DATABASE_PATH=./data/personal-trainer.sqlite

# Firebase backend / Hosting / Functions
# Mantenha false/omitido para runtime local/VPS SQLite.
FIREBASE_BACKEND=false
FIREBASE_FUNCTIONS_REGION=southamerica-east1
FUNCTIONS_REGION=southamerica-east1
FIREBASE_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
BOOTSTRAP_SECRET=
FIREBASE_BOOTSTRAP_SEED=empty
VITE_API_BASE_URL=/api/pt
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=

# Cloud Tasks para respostas assincronas da IA
CLOUD_TASKS_LOCATION=southamerica-east1
CLOUD_TASKS_QUEUE=pt-ai-responses
# Aponte para a URL direta da Function dedicada `claudeWorker`, nao para `/api/internal/*`.
CLOUD_TASKS_WORKER_URL=
CLOUD_TASKS_WORKER_AUDIENCE=
CLOUD_TASKS_SERVICE_ACCOUNT=
# O codigo aplica no minimo 1.5x GATEWAY_TIMEOUT_MS para evitar chamada Vertex duplicada.
CLOUD_TASKS_INFLIGHT_STALE_MS=600000
CLOUD_TASKS_ALLOW_DISABLED=false
FIREBASE_TASKS_EMULATE_INLINE=false

# Auth OIDC do worker ao ai-gateway
AI_GATEWAY_AUTH_AUDIENCE=
AI_GATEWAY_AUTH_DISABLED=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5174

# Rate Limiting
RATE_LIMIT_GLOBAL_MAX=60
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_CLAUDE_MAX=10
RATE_LIMIT_CLAUDE_WINDOW_MS=300000

# Token budget per-user (Sprint 3) — hard cap em tokens (input+output) por
# periodo. Pre-check antes de enfileirar Cloud Task; debita no worker apos
# response.ok do gateway. Reset diario as 00:00 UTC, mensal no dia 1.
# Defaults compatativeis com gemini-3-flash em uso intenso e nao-abusivo.
# Setar como 0 ou TOKEN_BUDGET_ENABLED=false desativa todo o gating.
TOKEN_BUDGET_DAILY=500000
TOKEN_BUDGET_MONTHLY=5000000
TOKEN_BUDGET_ENABLED=true
